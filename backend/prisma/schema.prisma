generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 Int                 @id @default(autoincrement())
  name               String
  email              String              @unique
  passwordHash       String
  role               Role
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  attendances        Attendance[]        @relation("StudentAttendances")
  attendanceSessions AttendanceSession[] @relation("TeacherSessions")
  student            Student?
  teacher            Teacher?
}

model Student {
  id         Int      @id @default(autoincrement())
  userId     Int      @unique
  rollNumber String   @unique
  department String
  semester   Int
  section    String
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([department, semester, section])
}

model Teacher {
  id         Int      @id @default(autoincrement())
  userId     Int      @unique
  employeeId String   @unique
  department String
  createdAt  DateTime @default(now())
  courses    Course[]
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AttendanceSession {
  id                 Int             @id @default(autoincrement())
  teacherId          Int
  sessionCode        String          @unique
  isActive           Boolean         @default(true)
  startedAt          DateTime        @default(now())
  endedAt            DateTime?
  createdAt          DateTime        @default(now())
  teacherSSID        String?
  teacherBSSID       String?
  courseId           Int?
  departmentSnapshot String?
  sectionSnapshot    String?
  semesterSnapshot   Int?
  attendanceRecords  Attendance[]
  course             Course?         @relation(fields: [courseId], references: [id], onDelete: Cascade)
  teacher            User            @relation("TeacherSessions", fields: [teacherId], references: [id], onDelete: Cascade)
  qrCodes            SessionQRCode[]

  @@index([courseId, isActive])
}

model Attendance {
  id                 Int               @id @default(autoincrement())
  studentId          Int
  sessionId          Int
  markedAt           DateTime          @default(now())
  verificationMethod String
  createdAt          DateTime          @default(now())
  status             String            @default("present")
  session            AttendanceSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  student            User              @relation("StudentAttendances", fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, sessionId])
}

model SessionQRCode {
  id        Int               @id @default(autoincrement())
  sessionId Int
  nonce     String            @unique
  expiresAt DateTime
  createdAt DateTime          @default(now())
  session   AttendanceSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model Course {
  id            Int                 @id @default(autoincrement())
  name          String
  teacherId     Int
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  archiveReason String?
  archivedAt    DateTime?
  department    String?
  isArchived    Boolean             @default(false)
  section       String?
  semester      Int?
  sessions      AttendanceSession[]
  teacher       Teacher             @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@index([teacherId, isArchived])
}

model UsedProximityToken {
  id        Int      @id @default(autoincrement())
  jti       String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([expiresAt])
}

enum Role {
  student
  teacher
  admin
}
