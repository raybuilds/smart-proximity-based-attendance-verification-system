generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 Int                 @id @default(autoincrement())
  name               String
  email              String              @unique
  passwordHash       String
  role               Role
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  isActive           Boolean             @default(true)
  needsPasswordChange Boolean            @default(false)
  attendances        Attendance[]        @relation("StudentAttendances")
  attendanceSessions AttendanceSession[] @relation("TeacherSessions")
  student            Student?
  teacher            Teacher?
}

model Student {
  id         Int      @id @default(autoincrement())
  userId     Int      @unique
  rollNumber String   @unique
  department String
  semester   Int
  section    String
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([department, semester, section])
}

model Teacher {
  id              Int      @id @default(autoincrement())
  userId          Int      @unique
  employeeId      String   @unique
  department      String
  registeredSSID  String?
  registeredBSSID String?
  createdAt       DateTime @default(now())
  courses         Course[]
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AttendanceSession {
  id                 Int             @id @default(autoincrement())
  teacherId          Int
  sessionCode        String          @unique
  isActive           Boolean         @default(true)
  startedAt          DateTime        @default(now())
  endedAt            DateTime?
  createdAt          DateTime        @default(now())
  teacherSSID        String?
  teacherBSSID       String?
  rssiThreshold      Int?
  courseId           Int?
  departmentSnapshot String?
  sectionSnapshot    String?
  semesterSnapshot   Int?
  attendanceRecords  Attendance[]
  course             Course?         @relation(fields: [courseId], references: [id], onDelete: Cascade)
  teacher            User            @relation("TeacherSessions", fields: [teacherId], references: [id], onDelete: Cascade)
  qrCodes            SessionQRCode[]

  @@index([courseId, isActive])
}

model Attendance {
  id                  Int                    @id @default(autoincrement())
  studentId           Int
  sessionId           Int
  markedAt            DateTime               @default(now())
  verificationMethod  String
  createdAt           DateTime               @default(now())
  status              String                 @default("present")
  correctionReason    String?
  method              AttendanceMethod       @default(QR)
  modifiedAt          DateTime?
  modifiedByTeacherId Int?
  session             AttendanceSession      @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  student             User                   @relation("StudentAttendances", fields: [studentId], references: [id], onDelete: Cascade)
  corrections         AttendanceCorrection[]

  // Audit trail metadata
  ssid           String?
  bssid          String?
  rssi           Int?
  devicePlatform String?

  @@unique([studentId, sessionId])
}

model AttendanceCorrection {
  id                  Int               @id @default(autoincrement())
  attendanceId        Int
  sessionId           Int
  studentId           Int
  previousMethod      AttendanceMethod?
  newMethod           AttendanceMethod?
  correctionReason    String
  modifiedByTeacherId Int
  modifiedAt          DateTime          @default(now())
  attendance          Attendance        @relation(fields: [attendanceId], references: [id], onDelete: Cascade)
}

model SessionQRCode {
  id        Int               @id @default(autoincrement())
  sessionId Int
  nonce     String            @unique
  expiresAt DateTime
  createdAt DateTime          @default(now())
  session   AttendanceSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model Course {
  id            Int                 @id @default(autoincrement())
  name          String
  teacherId     Int
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  archiveReason String?
  archivedAt    DateTime?
  department    String?
  isArchived    Boolean             @default(false)
  section       String?
  semester      Int?
  code          String?
  sessions      AttendanceSession[]
  teacher       Teacher             @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@index([teacherId, isArchived])
}

model UsedProximityToken {
  id        Int      @id @default(autoincrement())
  jti       String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([expiresAt])
}

enum AttendanceMethod {
  QR
  MANUAL
  AUTO_ABSENT
  SYSTEM_BACKFILL
}

enum Role {
  student
  teacher
  admin
}
