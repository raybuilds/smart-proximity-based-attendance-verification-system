{
  "name": "attendance-system-backend",
  "version": "1.0.0",
  "description": "Backend for Attendance System",
  "main": "src/index.js",
  "scripts": {
    "dev": "node src/app.js",
    "dev:clean": "powershell -Command \"$p = Get-NetTCPConnection -LocalPort 5000 -ErrorAction SilentlyContinue; if ($p) { Stop-Process -Id $p.OwningProcess -Force }\" & node src/app.js",
    "health-check": "node src/scripts/smoke-test.js",
    "audit:snapshot": "node audit/pre_audit_snapshot.js",
    "audit:verify": "node audit/post_cleanup_verify.js",
    "audit:test:id": "node audit/tests/generateAuditRunId.test.js",
    "audit:test:teacher": "node audit/tests/teacher_isolation.test.js",
    "audit:test:race": "node audit/tests/session_race_condition.test.js",
    "audit:test:load": "node audit/tests/load_test.js",
    "audit:test:spike": "node audit/tests/instant_classroom_spike.test.js",
    "audit:test:coldstart": "node audit/tests/render_cold_start.test.js",
    "audit:test:replay": "node audit/tests/replay_protection.test.js",
    "audit:test:collision": "node audit/tests/token_collision.test.js",
    "audit:test:dashboard": "node audit/tests/dashboard_consistency.test.js",
    "audit:test:reporting": "node audit/tests/reporting_reliability.test.js",
    "audit:test:closure": "node audit/tests/session_closure.test.js",
    "audit:test:integrity": "node audit/tests/database_integrity.test.js",
    "audit:run": "node audit/run_audit.js"
  },
  "dependencies": {
    "@prisma/client": "^5.0.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^16.0.0",
    "express": "^5.2.1",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.11.0",
    "pdfkit": "^0.19.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "mocha": "^10.0.0",
    "prisma": "^5.0.0"
  }
}
