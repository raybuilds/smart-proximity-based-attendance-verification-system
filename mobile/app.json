{
  "expo": {
    "name": "Attendance System App",
    "slug": "attendance-system-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Location access is required to scan nearby WiFi for attendance verification."
      }
    },
"android": {
  "permissions": [
    "ACCESS_FINE_LOCATION",
    "ACCESS_WIFI_STATE",
    "CHANGE_WIFI_STATE",
    "NEARBY_WIFI_DEVICES",
    "BLUETOOTH_SCAN",
    "BLUETOOTH_CONNECT"
  ],
  "adaptiveIcon": {
    "backgroundColor": "#ffffff"
  },
  "package": "com.anonymous.attendancesystemapp"
},
    "web": {
      "bundler": "metro"
    }
  }
}
